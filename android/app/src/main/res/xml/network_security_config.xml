<?xml version="1.0" encoding="utf-8"?>
<!-- Replace cleartext domains with your HTTPS host once TLS is live; then remove domain-config entries. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">187.124.35.51</domain>
        <domain includeSubdomains="false">3.88.167.66</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
